    "cpos:bootstrap": "npm --prefix app run cpos:bootstrap --silent --",
    "cpos:analyze": "npm --prefix app run cpos:analyze --silent --",
    "setup:gcp": "npm --prefix app run setup:gcp --silent --",
    "setup:domain": "npm --prefix app run setup:domain --silent --",
    "deploy:cloudrun": "npm --prefix app run deploy:cloudrun --silent",
    "deploy:cloudrun:local": "npm --prefix app run deploy:cloudrun:local --silent",
    "logs": "npm --prefix app run logs --silent --",
    "test:smoke": "npm --prefix app run test:smoke --silent"
