# =====================================================
# 加算マネージャー Web版 環境変数サンプル
# 本番デプロイ時はこのファイルを参考に .env を作成してください
# .env は .gitignore で除外されます。秘密情報をコミットしないでください。
#
# ▶ 本構成では Cloud Run も .env の値で動かします
#   - npm run deploy:cloudrun が .env を読み込み、`gcloud run deploy --set-env-vars=...`
#     で Cloud Run の環境変数として GEMINI_API_KEY を直接渡します
#   - Secret Manager は使いません（必要なら `--use-secret` で従来挙動）
# =====================================================

# ----- Gemini API -----
# Google AI Studio で取得した API キー: https://aistudio.google.com/app/apikey
# 本番では Cloud Run の環境変数として直接渡されます。
GEMINI_API_KEY=your-gemini-api-key-here

# 利用するモデル名（任意。未指定時は gemini-2.5-flash）
# 高精度: gemini-2.5-pro / 高速: gemini-2.5-flash / 軽量: gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# ----- サーバー設定 -----
# Cloud Run では PORT は自動で 8080 が割り当てられます。ローカル実行時のみ指定。
PORT=8080
HOST=0.0.0.0

# 本番運用時は production を指定
NODE_ENV=production

# ----- アップロード制限 -----
# 1ファイル当たりの最大サイズ（バイト）。デフォルト 20MB。
MAX_UPLOAD_BYTES=20971520

# ----- レート制限（IP ベース） -----
# false にすると全レート制限を無効化（ローカル開発用）
RATE_LIMIT_ENABLED=true
# /api/services や /api/health 等の一般 API 上限（窓ミリ秒あたり）
RATE_LIMIT_GENERAL_MAX=60
RATE_LIMIT_GENERAL_WINDOW_MS=600000
# /api/analyze, /api/judge, /api/import-receipt 等の高コスト API 上限
RATE_LIMIT_HEAVY_MAX=10
RATE_LIMIT_HEAVY_WINDOW_MS=600000

# Cloud Run / LB の前段プロキシ数。Cloud Run 直は 1、LB 経由なら 2 が目安
TRUST_PROXY=1

# ----- Google reCAPTCHA v3 -----
# 設定しない場合（site_key/secret 空）は自動で無効化されます。
# https://www.google.com/recaptcha/admin で v3 を新規作成し、ドメインを登録してください
RECAPTCHA_ENABLED=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# 0.0〜1.0 の閾値。これ未満は bot とみなして 403 を返す（デフォルト 0.5）
RECAPTCHA_MIN_SCORE=0.5

# =====================================================
# Cloud Run / GCP 用変数（npm run setup:gcp / deploy:cloudrun が参照）
# =====================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=kasan-manager
CLOUD_RUN_MEMORY=1Gi
CLOUD_RUN_CPU=1
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=3

# Artifact Registry リポジトリ名（無ければ setup:gcp が作成）
GCP_ARTIFACT_REPO=kasan-manager

# Secret Manager 連携を opt-in する場合のみ使用（通常は不要）
CLOUD_RUN_SECRET_NAME=gemini-api-key

# =====================================================
# CPOS アプリ連携（ログイン・ユーザー管理・データ保存を CPOS に集約）
# =====================================================
# 加算マネージャは CPOS の App Platform にアプリ(appId=kasan)として登録し、発行された
# App Token で CPOS API（app-data / facilities / analysis-source 等）を呼びます。
# ユーザーは「CPOS でログイン」で認証し、加算マネージャ独自の保存（DB/ファイル）は持ちません。
# 詳細: docs/AUTH_AND_PLANS.md / docs/CPOS_INTEGRATION.md / ref/KASAN_APP_API_ADDITIONS.md

# 必須: セッション Cookie の暗号鍵（32 文字以上）。CPOS ログインのセッション cookie に使用。
#   例: openssl rand -hex 32
KASAN_SESSION_SECRET=

# 必須: CPOS のベース URL（例: https://cpos.example.jp）
KASAN_DEFAULT_CPOS_BASE_URL=

# 必須: CPOS 管理コンソール /app-tokens で発行した App Token（Bearer, cpos_pat_...）。
#   推奨 scopes: app-data:kasan:read app-data:kasan:write users:read facilities:read
#   （CPOS 実データ活用: master-users:read / facility-staff:read / care-* も任意で）
KASAN_CPOS_APP_TOKEN=

# 任意: CPOS 側のアプリ識別（ログ突合用）。既定 kasan
KASAN_CPOS_APP_CLIENT_ID=kasan

# 任意: OAuth コールバックの公開 URL ベース（未指定時はリクエストの host から推定）。
#   例: https://kasan.example.jp → コールバックは {base}/api/auth/cpos/callback
KASAN_PUBLIC_BASE_URL=

# 任意: 管理者 email のカンマ区切り（CPOS の role=admin に加えた override）
KASAN_ADMIN_EMAILS=

# 開発・結合テスト用: 1 でプロセス内 Fake CPOS を使う（本番では未設定のまま）
KASAN_CPOS_FAKE=

# Cookie の属性（本番では Secure=true / SameSite=Lax 推奨）
KASAN_COOKIE_SECURE=true
KASAN_COOKIE_SAMESITE=Lax

# CPOS への HTTP タイムアウト（ms）。未指定時は 30000
CPOS_TIMEOUT_MS=

# Secret Manager 経由のシークレット参照（Cloud Run 推奨）
# 値は projects/X/secrets/Y/versions/latest のような Secret Manager リソース名。
# 未設定なら上の生 env を fallback として使う。
KASAN_SECRET_SESSION_NAME=
KASAN_SECRET_GEMINI_NAME=
KASAN_SECRET_RECAPTCHA_NAME=
KASAN_SECRET_CPOS_APP_TOKEN_NAME=

# =====================================================
# カスタムドメイン（npm run setup:domain が参照）
# =====================================================
# 例: kasan.example.jp
CLOUD_RUN_CUSTOM_DOMAIN=

# ロードバランサ方式（--mode=loadbalancer）で使用するリソース名
CLOUD_RUN_LB_NAME=kasan-manager-lb
CLOUD_RUN_LB_IP_NAME=kasan-manager-lb-ip
CLOUD_RUN_LB_CERT_NAME=kasan-manager-lb-cert
CLOUD_RUN_LB_NEG_NAME=kasan-manager-neg
